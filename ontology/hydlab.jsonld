  {
    "@id": "https://purl.org/hydlab/ns",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://purl.org/dc/terms/created": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2024-01-01"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "\n        The H2SmartLab Ontology (HYDLAB) describes the structure of a hydrogen\n        smart laboratory including its organisational context, physical infrastructure,\n        process units, electrochemical devices, and sensor measurement apparatus.\n        It aligns with W3C SOSA/SSN for sensor observations, EMMO for devices,\n        OEO for power plant concepts, and schema.org for organisations.\n    "
      }
    ],
    "http://purl.org/dc/terms/license": [
      {
        "@id": "https://creativecommons.org/licenses/by-sa/4.0/"
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@language": "en",
        "@value": "H2SmartLab Ontology"
      }
    ],
    "http://purl.org/vocab/vann/preferredNamespacePrefix": [
      {
        "@value": "hydlab"
      }
    ],
    "http://purl.org/vocab/vann/preferredNamespaceURI": [
